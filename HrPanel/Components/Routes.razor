@using Microsoft.AspNetCore.Components.Authorization
@inject IServiceProvider ServiceProvider

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated == true)
                    {
                        @* Kullanıcı giriş yapmış ama bu sayfaya yetkisi yok *@
                        <div class="container mt-5">
                            <div class="alert alert-danger text-center shadow-sm">
                                <i class="bi bi-shield-lock-fill fs-1"></i>
                                <h4 class="fw-bold mt-2">Erişim Engellendi!</h4>
                                <p>Bu sayfayı görüntülemek için gerekli yetkiye sahip değilsiniz.</p>
                                <a href="/" class="btn btn-outline-danger btn-sm">Dashboard'a Dön</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        @*prerender korumalı bölge *@
                        <div class="text-center mt-5 py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3 text-muted">Oturum bilgileriniz doğrulanıyor, lütfen bekleyin...</p>
                        </div>

                        @*  Yönlendirme mantığını OnAfterRenderAsynce *@
                        <RedirectToLogin />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <p role="alert">Üzgünüz, aradığınız sayfa bulunamadı.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>