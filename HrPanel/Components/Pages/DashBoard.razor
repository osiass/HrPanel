@page "/"
@attribute [Authorize]
@using HrPanel.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using HrPanel.Models
@using HrPanel.Data
@inject DashboardService DashService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-4"><i class="bi bi-speedometer2"></i> Genel Bakış</h2>
        <div class="text-muted">@DateTime.Now.ToString("dd MMMM yyyy, dddd")</div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Toplam Personel -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between px-md-1">
                        <div>
                            <h3 class="fw-bold">@stats.TotalEmployees</h3>
                            <p class="mb-0">Toplam Personel</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-people fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aktif Personel -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between px-md-1">
                        <div>
                            <h3 class="fw-bold">@stats.ActiveEmployees</h3>
                            <p class="mb-0">Aktif Çalışan</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-person-check fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Departmanlar -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between px-md-1">
                        <div>
                            <h3 class="fw-bold">@stats.TotalDepartments</h3>
                            <p class="mb-0">Departman Sayısı</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-building fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ortalama Maaş -->
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between px-md-1">
                        <div>
                            <h3 class="fw-bold">@stats.AverageSalary.ToString("C2")</h3>
                            <p class="mb-0">Ortalama Maaş</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-cash-stack fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--bilgi -->
    <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white fw-bold d-flex justify-content-between">
            <span><i class="bi bi-person-plus"></i> Son Eklenen Personeller</span>
            <a href="/personeller" class="btn btn-sm btn-link p-0 text-decoration-none">Tümünü Gör</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light small">
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Departman</th>
                        <th>Maaş</th>
                    </tr>
                </thead>
                <tbody style="font-size: 0.9rem;">
                    @foreach (var emp in stats.RecentEmployees)
                    {
                        <tr>
                            <td>@emp.FullName</td>
                            <td><span class="badge bg-light text-dark">@emp.Department?.Name</span></td>
                            <td>@emp.Salary.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    // DashboardStats nesnesi servisten dönen tüm istatistikleri içinde barındırır
    private DashboardStats stats = new();

    protected override async Task OnInitializedAsync()
    {
        // Tüm istatistikleri servisten tek bir paket (DTO) olarak alıyoruz
        stats = await DashService.GetDashboardStatsAsync();
    }
}