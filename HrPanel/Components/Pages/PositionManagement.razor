@page "/pozisyonlar"
@attribute [Authorize]
@attribute [Authorize(Roles = "Admin")]
@using HrPanel.Models
@using HrPanel.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject PositionService PosService

<div class="container mt-4 animate__animated animate__fadeIn">
    <h3 class="fw-bold mb-4"><i class="bi bi-briefcase"></i> Pozisyon Yönetimi</h3>

    <div class="row">
        <!-- YENİ POZİSYON EKLEME FORMU -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white">Yeni Pozisyon Ekle</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Pozisyon Adı</label>
                        <input type="text" class="form-control" placeholder="Pozisyon Adı Giriniz"
                               @bind="newPosition.Name" />
                    </div>
                    <button class="btn btn-primary w-100" @onclick="SavePosition">
                        <i class="bi bi-plus-circle"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>

        <!-- LİSTELEME TABLOSU -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Pozisyon Adı</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (positionList == null || !positionList.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">Henüz pozisyon tanımlanmamış.</td>
                            </tr>
                        }
                        else
                        {
                            int siraNo = 1;
                            @foreach (var pos in positionList)
                            {
                                <tr>
                                    <td>@siraNo</td>
                                    <td><strong>@pos.Name</strong></td>
                                    <td class="text-end">
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeletePosition(pos.Id)">
                                            <i class="bi bi-trash"></i> Sil
                                        </button>
                                    </td>
                                </tr>
                                siraNo++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Position> positionList = new();
    private Position newPosition = new();
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        positionList = await PosService.GetAllPositionsAsync();
    }

    public async Task SavePosition()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newPosition.Name))
        {
            errorMessage = "Pozisyon adı boş olamaz.";
            return;
        }

        await PosService.AddPositionAsync(newPosition);

        newPosition = new Position(); // Formu temizle
        await LoadAsync();
    }

    public async Task DeletePosition(int id)
    {
        await PosService.DeletePositionAsync(id);

        await LoadAsync();
    }
}