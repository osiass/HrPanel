@page "/personeller"
@attribute [Authorize]
@using HrPanel.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using HrPanel.Models
@using HrPanel.Data
@inject EmployeeService EmpService
@inject DepartmentService DeptService
@inject PositionService PosService


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-4"><i class="bi bi-people-fill"></i> Personel Yönetimi</h2>
    </div>

    <div class="row">
        <!-- YENİ PERSONEL EKLEME FORMU -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header @(newEmployee.Id == 0 ? "bg-dark" : "bg-warning") text-white">
                    @* başlık id durumuna göre değişiyor *@
                    <h5 class="mb-0">@(newEmployee.Id == 0 ? "Yeni Personel Kaydı" : "Personel Düzenle")</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ad Soyad</label>
                        <input type="text" class="form-control" placeholder="Ad Soyad giriniz"
                               @bind="newEmployee.FullName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">E-Posta</label>
                        <input type="email" class="form-control" placeholder="E-posta giriniz"
                               @bind="newEmployee.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Pozisyon</label>
                        @* Pozisyon alanı veritabanından gelen listeden seçiliyor *@
                        <select class="form-select" @bind="newEmployee.PositionId">
                            <option value="0">Seçiniz...</option>
                            @foreach (var pos in positionList)
                            {
                                <option value="@pos.Id">@pos.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Maaş</label>
                        <input type="number" class="form-control" @bind="newEmployee.Salary" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Departman</label>
                        <select class="form-select" @bind="newEmployee.DepartmentId">
                            <option value="0">Seçiniz...</option>
                            @foreach (var dept in departmentList)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>

                    @* Personel Aktiflik Durumu Kontrolü *@
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isActiveCheck" @bind="newEmployee.IsActive" />
                        <label class="form-check-label fw-bold" for="isActiveCheck text-primary">Personel Aktif mi?</label>
                    </div>

                    @*buton rengi ve metni Id durumuna göre değişiyor *@
                    <button class="btn @(newEmployee.Id == 0 ? "btn-success" : "btn-warning") w-100 py-2 fw-bold" @onclick="SaveEmployee">
                        <i class="bi @(newEmployee.Id == 0 ? "bi-check-circle" : "bi-arrow-repeat")"></i>
                        @(newEmployee.Id == 0 ? "Personeli Kaydet" : "Değişiklikleri Güncelle")
                    </button>

                    @if (newEmployee.Id > 0)
                    {
                        <button class="btn btn-link w-100 mt-2 text-decoration-none text-muted" @onclick="CancelEdit">Düzenlemeyi İptal Et</button>
                    }
                </div>
            </div>
        </div>

        <!--PERSONEL LİSTESİ -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Personel</th>
                                <th>Departman</th>
                                <th>Pozisyon</th>
                                <th>Maaş</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (employeeList == null || !employeeList.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        Henüz kayıtlı personel bulunamadı.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var emp in employeeList)
                                {
                                    <tr class="@(emp.IsActive ? "" : "opacity-50")">
                                        <td>
                                            <div class="fw-bold">@emp.FullName</div>
                                            <small class="text-muted">@emp.Email</small>
                                        </td>
                                        <td><span class="badge bg-info text-dark">@emp.Department?.Name</span></td>
                                        <td>@emp.Position?.Name</td>
                                        <td>@emp.Salary.ToString("C2")</td>
                                        <td class="text-center">
                                            @*Düzenle butonu *@
                                            <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => PrepareForEdit(emp)">
                                                <i class="bi bi-pencil"></i> Düzenle
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteEmployee(emp.Id)">
                                                <i class="bi bi-trash"></i> Sil
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Employee> employeeList = new();
    private List<Department> departmentList = new();
    private List<Position> positionList = new();
    private Employee newEmployee = new Employee();

    protected override async Task OnInitializedAsync()//sayfa ilk açıldığında loadasync tetikle
    {
        await LoadAsync();
    }

    public async Task LoadAsync()//veritabanından personel ve departman bilgilerini çek
    {
        employeeList = await EmpService.GetAllEmployeesAsync();
        departmentList = await DeptService.GetAllDepartmentsAsync();
        positionList = await PosService.GetAllPositionsAsync();
    }

    public async Task SaveEmployee()
    {
        if (string.IsNullOrWhiteSpace(newEmployee.FullName) || newEmployee.DepartmentId == 0 || newEmployee.PositionId == 0)
        {
            return;
        }

        if (newEmployee.Id == 0)
        {
            await EmpService.AddEmployeeAsync(newEmployee);
        }
        else
        {
            await EmpService.UpdateEmployeeAsync(newEmployee);
        }

        newEmployee = new Employee();//formu temizle
        await LoadAsync();

    }

    public async Task DeleteEmployee(int id)
    {
        await EmpService.DeleteEmployeeAsync(id);
        await LoadAsync();
    }

    // Seçilen personeli forma yükler
    private void PrepareForEdit(Employee emp)
    {
        newEmployee = new Employee //formda isim değiştiği an personel bilgileri güncellenir veritabanına kaydetmeden
        {
            Id = emp.Id,
            FullName = emp.FullName,
            Email = emp.Email,
            Salary = emp.Salary,
            DepartmentId = emp.DepartmentId,
            PositionId = emp.PositionId,
            IsActive = emp.IsActive
        };
    }

    // Düzenlemeyi iptal etme formu boşaltır
    private void CancelEdit()
    {
        newEmployee = new Employee();
    }
}