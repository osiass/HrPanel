@page "/departmanlar"
@attribute [Authorize]
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using HrPanel.Models
@using HrPanel.Data
@using HrPanel.Services
@inject DepartmentService DeptService

<div class="container mt-4">
    <h3 class="fw-bold mb-4"><i class="bi bi-building"></i> Departman Yönetimi</h3>
    <hr />

    <div class="card mb-4">
        <div class="card-header">Yeni Departman Ekle</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <input type="text" class="form-control" placeholder="Departman Adı Giriniz"
                           @bind="newDeptName" />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100" @onclick="AddDepartment">
                        <i class="bi bi-plus-circle"></i> Kaydet
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="text-danger mt-2">@errorMessage</div>
            }
        </div>
    </div>

    <!--LİSTELEME TABLOSU-->
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Departman Adı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (departmentList == null || !departmentList.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4">Henüz kayıt bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        int siraNo = 1;
                        @foreach (var dept in departmentList)
                        {
                            <tr>
                                <td>@siraNo</td>
                                <td>@dept.Name</td>
                                <td class="text-end">
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteDepartment(dept.Id)">
                                        Sil
                                    </button>
                                </td>
                            </tr>
                            siraNo++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Department> departmentList = new();
    private string newDeptName = "";
    private string errorMessage = "";

    // Sayfa açıldığında verileri yükle
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // Servis üzerinden tüm departmanları getiriyoruz
        departmentList = await DeptService.GetAllDepartmentsAsync();
    }

    private async Task AddDepartment()
    {
        if (string.IsNullOrWhiteSpace(newDeptName))
        {
            errorMessage = "Lütfen bir isim yazın!";
            return;
        }

        var d = new Department { Name = newDeptName };

        // Veriyi servise gönderiyoruz
        await DeptService.AddDepartmentAsync(d);

        newDeptName = ""; // temizle
        errorMessage = ""; // hata mesajını sil
        await LoadData();  // listeyi yenile
    }

    private async Task DeleteDepartment(int id)
    {
        await DeptService.DeleteDepartmentAsync(id);

        await LoadData();
    }
}