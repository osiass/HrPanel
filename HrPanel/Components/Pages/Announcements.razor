@page "/duyurular"
@attribute [Authorize(Roles = "Admin")]
@using HrPanel.Models
@using HrPanel.Services
@using Microsoft.AspNetCore.Authorization
@inject AnnouncementService AnnouncementService
@inject NavigationManager Nav

<div class="container-fluid animate__animated animate__fadeIn">
    @*Yeni duyuru butonu *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-megaphone me-2 text-primary"></i>Duyuru Yönetimi</h2>
            <p class="text-muted small mb-0">Şirket içi haberleri ve duyuruları buradan yayınlayabilirsiniz.</p>
        </div>
        <button class="btn btn-primary shadow-sm px-4 fw-bold" @onclick="() => showCreateModal = true">
            <i class="bi bi-plus-lg me-2"></i>Yeni Duyuru Yayınla
        </button>
    </div>

    @* Duyuru Listesi *@
    <div class="card glass-card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light small text-muted text-uppercase fw-bold">
                        <tr>
                            <th class="ps-4">Başlık</th>
                            <th>Tarih</th>
                            <th>Öncelik</th>
                            <th>Durum</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (announcements == null || !announcements.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-megaphone fs-2 d-block mb-2"></i>
                                    Henüz bir duyuru bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in announcements)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@item.Title</div>
                                        <div class="small text-muted text-truncate" style="max-width: 400px;">@item.Content</div>
                                    </td>
                                    <td class="small text-muted">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @(item.Priority == "Yüksek" ? "bg-danger" : "bg-info") px-3 py-2 rounded-pill">
                                            @item.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" checked="@item.IsActive" readonly />
                                            <span class="small">@(item.IsActive ? "Aktif" : "Pasif")</span>
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => DeleteAnnouncement(item.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Yeni Duyuru Modalı *@
@if (showCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg animate__animated animate__zoomIn">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-megaphone me-2"></i>Yeni Duyuru Oluştur</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Duyuru Başlığı</label>
                        <input type="text" class="form-control" @bind="newAnnouncement.Title" placeholder="Duyuru başlığını giriniz" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Öncelik</label>
                        <select class="form-select" @bind="newAnnouncement.Priority">
                            <option value="Normal">Normal</option>
                            <option value="Yüksek">Yüksek </option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Duyuru İçeriği</label>
                        <textarea class="form-control" rows="5" @bind="newAnnouncement.Content" placeholder="Duyuru detaylarını buraya yazınız"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light px-4" @onclick="() => showCreateModal = false">Vazgeç</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold" @onclick="SaveAnnouncement">Yayınla</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Announcement> announcements = new();
    private Announcement newAnnouncement = new();
    private bool showCreateModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
  
        announcements = await AnnouncementService.GetAllAnnouncementsAsync();
    }

    private async Task SaveAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(newAnnouncement.Title) || string.IsNullOrWhiteSpace(newAnnouncement.Content))
            return;

        newAnnouncement.CreatedDate = DateTime.Now;
        newAnnouncement.IsActive = true;

        await AnnouncementService.AddAnnouncementAsync(newAnnouncement);
        
        newAnnouncement = new Announcement(); // burda yeni nesne oluşturmazsak modalda eski veriler kalır
        showCreateModal = false;
        await LoadData();
    }

    private async Task DeleteAnnouncement(int id)
    {
        await AnnouncementService.DeleteAnnouncementAsync(id);
        await LoadData();
    }
}
