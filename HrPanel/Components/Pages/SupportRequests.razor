@page "/destek"
@attribute [Authorize]
@using HrPanel.Models
@using HrPanel.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject SupportService SupportService
@inject EmployeeService EmployeeService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container-fluid animate__animated animate__fadeIn">
    @*teni talep butonu*@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-headset me-2 text-primary"></i>Destek Talepleri</h2>
            <p class="text-muted small mb-0">Teknik veya idari konularda yardım taleplerinizi buradan yönetebilirsiniz.</p>
        </div>
        <button class="btn btn-success shadow-sm px-4 fw-bold" @onclick="() => showCreateModal = true">
            <i class="bi bi-plus-lg me-2"></i>Yeni Destek Talebi
        </button>
    </div>

    @*destek talepleri listesi *@
    <div class="card glass-card border-0 shadow-sm overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light small text-muted text-uppercase fw-bold">
                        <tr>
                            <th class="ps-4" style="width: 80px;">ID</th>
                            <th>Konu</th>
                            <th>Talep Eden</th>
                            <th>Ürün / Kategori</th>
                            <th>Durum</th>
                            <th class="text-center"><i class="bi bi-chat-left-text"></i></th>
                            <th class="text-center"><i class="bi bi-paperclip"></i></th>
                            <th>Oluşturma Tarihi</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (requests == null || !requests.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    Henüz bir destek talebi bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var request in requests)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@request.Id</td>
                                    <td>
                                        <div class="fw-bold">@request.Subject</div>
                                        <div class="small text-muted text-truncate" style="max-width: 300px;">@request.Description</div>
                                    </td>
                                    <td>
                                        <div class="fw-bold">@request.RequesterEmployee?.FullName</div>
                                        <div class="small text-muted">@request.RequesterEmployee?.Email</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded">@request.Product</span>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(request.Status) px-3 py-2 rounded-pill">@request.Status</span>
                                    </td>
                                    <td class="text-center text-muted small">@request.CommentCount</td>
                                    <td class="text-center text-muted small">@request.FileCount</td>
                                    <td class="text-muted small">@request.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-outline-primary border-0" title="Görüntüle">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <AuthorizeView Roles="Admin">
                                            <Authorized>
                                                <div class="btn-group ms-2">
                                                    @if (request.Status != "Çözüldü")
                                                    {
                                                        <button class="btn btn-sm btn-outline-success border-0" @onclick='() => UpdateStatus(request.Id, "Çözüldü")'>
                                                            <i class="bi bi-check-circle"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </Authorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@*yeni talep oluşturma modalı *@
@if (showCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg animate__animated animate__zoomIn">
                <div class="modal-header bg-dark text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2"></i>Yeni Destek Talebi</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Konu Başlığı</label>
                        <input type="text" class="form-control" @bind="newRequest.Subject" placeholder="Hata mesajı" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Kategori</label>
                        <select class="form-select" @bind="newRequest.Product">
                            <option value="İnsan Kaynakları">İnsan Kaynakları</option>
                            <option value="IT / Bilgi İşlem">IT / Bilgi İşlem</option>
                            <option value="Bordro ve Özlük">Bordro ve Özlük</option>
                            <option value="Diğer">Diğer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Açıklama</label>
                        <textarea class="form-control" rows="4" @bind="newRequest.Description" placeholder="Lütfen sorununuzu detaylıca açıklayınız..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light px-4" @onclick="() => showCreateModal = false">Vazgeç</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold" @onclick="SubmitRequest">Talebi Gönder</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SupportRequest> requests = new();
    private SupportRequest newRequest = new();
    private bool showCreateModal = false;
    private int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        // Oturum açan kullanıcıyı al
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        
        if (int.TryParse(userIdClaim, out currentUserId))
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        // Admin her şeyi görsün normal kullanıcı sadece kendi taleplerini
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin"))
        {
            requests = await SupportService.GetAllRequestsAsync();
        }
        else
        {
            requests = await SupportService.GetMyRequestsAsync(currentUserId);
        }
    }

    private async Task SubmitRequest()
    {
        if (string.IsNullOrWhiteSpace(newRequest.Subject) || string.IsNullOrWhiteSpace(newRequest.Description))
            return;

        newRequest.RequesterEmployeeId = currentUserId;
        newRequest.CreatedDate = DateTime.Now;
        newRequest.Status = "Yeni";

        await SupportService.AddRequestAsync(newRequest);
        
        // Formu temizle ve kapat
        newRequest = new SupportRequest();
        showCreateModal = false;
        await LoadData();
        StateHasChanged();
    }

    private async Task UpdateStatus(int id, string status)
    {
        await SupportService.UpdateStatusAsync(id, status);
        await LoadData();
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Yeni" => "bg-primary bg-opacity-10 text-primary border border-primary-subtle",
        "Açık" => "bg-warning bg-opacity-10 text-warning border border-warning-subtle",
        "Çözüldü" => "bg-success bg-opacity-10 text-success border border-success-subtle",
        _ => "bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle"
    };
}
