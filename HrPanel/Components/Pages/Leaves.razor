@page "/izinler"
@attribute [Authorize]
@using HrPanel.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using HrPanel.Models
@using HrPanel.Services
@using System.Security.Claims
@inject LeaveService LeaveService
@inject EmployeeService EmployeeService
@inject AuthenticationStateProvider AuthStateProvider

<div class="container mt-4">
    <h3 class="fw-bold mb-4"><i class="bi bi-calendar-check"></i> İzin Talepleri</h3>

    <div class="row">
        <!-- İZİN TALEBİ FORMU -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white">Talep Oluştur</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Personel</label>
                        @if (currentUserRole == EmployeeRole.Employee)
                        {
                            @* Employee ise sadece kendini görür, değiştiremez *@
                            <input type="text" class="form-control bg-light" value="@employeeList.FirstOrDefault()?.FullName" readonly />
                        }
                        else
                        {
                            @* Admin veya Manager ise herkesi seçebilir *@
                            <select class="form-select" @bind="newLeave.EmployeeId">
                                <option value="0">Personel Seçiniz...</option>
                                @foreach (var emp in employeeList)
                                {
                                    <option value="@emp.Id">@emp.FullName</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Başlangıç</label>
                        <input type="date" class="form-control" @bind="newLeave.StartDate" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bitiş</label>
                        <input type="date" class="form-control" @bind="newLeave.EndDate" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" @bind="newLeave.Description"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger py-2 mt-2" style="font-size: 0.85rem;">
                            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                        </div>
                    }

                    <button class="btn btn-primary w-100 mt-2" @onclick="SaveLeave">
                        <i class="bi bi-send"></i> İzin Talebi Oluştur
                    </button>
                </div>
            </div>
        </div>

        <!-- İZİN LİSTESİ -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <table class="table table-hover align-middle">
                    <thead class="table-light small text-uppercase">
                        <tr>
                            <th>Personel</th>
                            <th>Tarih Aralığı</th>
                            <th>Gün</th>
                            <th>Aşama</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var leave in leaveList)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@leave.Employee?.FullName</div>
                                    <div class="small text-muted">@leave.Type</div>
                                </td>
                                <td>@leave.StartDate.ToShortDateString() - @leave.EndDate.ToShortDateString()</td>
                                <td><span class="badge bg-light text-dark border">@((leave.EndDate - leave.StartDate).Days) Gün</span></td>
                                <td>
                                    @* Statüye göre farklı renklerde badge *@
                                    @if (leave.Status == LeaveStatus.PendingManager)
                                    {
                                        <span class="badge bg-warning text-dark">Amir Onayı Bekliyor</span>
                                    }
                                    else if (leave.Status == LeaveStatus.PendingHR)
                                    {

                                        <span class="badge bg-info text-dark">İK Onayı Bekliyor</span>
                                    }
                                    else if (leave.Status == LeaveStatus.Approved)
                                    {

                                        <span class="badge bg-success">Onaylandı</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger">Reddedildi</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @* SADECE ADMIN VEYA ILGILI AMIRSE BUTONLARI GÖSTER *@
                                    @if (leave.Status != LeaveStatus.Approved && leave.Status != LeaveStatus.Rejected)
                                    {
                                        @* Employee ise onay butonlarını görmesin *@
                                        <AuthorizeView Roles="Admin, Manager">
                                            <div class="btn-group shadow-sm">
                                                <button class="btn btn-sm btn-success" @onclick="() => ProcessApproval(leave.Id, true)">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                                <button class="btn btn-sm btn-danger" @onclick="() => ProcessApproval(leave.Id, false)">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </div>
                                        </AuthorizeView>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Leave> leaveList = new();
    private List<Employee> employeeList = new();
    private Leave newLeave = new Leave { StartDate = DateTime.Now, EndDate = DateTime.Now.AddDays(1) };
    private string errorMessage = "";
    private int currentUserId;
    private EmployeeRole currentUserRole;

    protected override async Task OnInitializedAsync()
    {
        // CS0120 hatası enjekte edilen değişkeni küçük harfle değişken adıyla çağırıyoruz
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var roleClaim = user.FindFirst(ClaimTypes.Role)?.Value;

        if (userIdClaim != null && roleClaim != null)
        {
            currentUserId = int.Parse(userIdClaim);
            currentUserRole = Enum.Parse<EmployeeRole>(roleClaim);

            // eğer employee ise formu otomatik onun idsine kilitle
            if (currentUserRole == EmployeeRole.Employee)
            {
                newLeave.EmployeeId = currentUserId;
            }
        }

        await LoadAsync();
    }

    public async Task LoadAsync()
    {
        // employee sadece kendi izinlerini Admin-Manager ise yetkili olduğu izinleri çeker
        if (currentUserRole == EmployeeRole.Employee)
        {
            leaveList = await LeaveService.GetMyLeavesAsync(currentUserId);
            // Employee başkasını seçemesin diye listeyi sadece kendisiyle dolduruyoruz
            var me = await EmployeeService.GetEmployeeByIdAsync(currentUserId);
            employeeList = me != null ? new List<Employee> { me } : new List<Employee>();
        }
        else
        {
            leaveList = await LeaveService.GetPendingLeavesAsync(currentUserId, currentUserRole);

            // Tüm personelleri servisten çekiyoruz
            var allEmployees = await EmployeeService.GetAllEmployeesAsync();

            if (currentUserRole == EmployeeRole.Manager)
            {
                // müdürler sadece admin olmayanları listede görebilir
                employeeList = allEmployees.Where(e => e.Role != EmployeeRole.Admin).ToList();
            }
            else
            {
                // Admin her şeyi görebilir
                employeeList = allEmployees;
            }
        }
    }

    public async Task SaveLeave()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newLeave.Description) || newLeave.EmployeeId == 0)
        {
            errorMessage = "Lütfen tüm alanları doldurun.";
            return;
        }

        if (newLeave.EndDate < newLeave.StartDate)
        {
            errorMessage = "Bitiş tarihi başlangıç tarihinden önce olamaz";
            return;
        }

        else
        {
            await LeaveService.AddLeaveAsync(newLeave);

            // Formu temizlerken mevcut kullanıcının IDsini koruyoruz 
            newLeave = new Leave { StartDate = DateTime.Now, EndDate = DateTime.Now.AddDays(1) };
            if (currentUserRole == EmployeeRole.Employee) newLeave.EmployeeId = currentUserId;

            await LoadAsync();
        }

    }

    public async Task UpdateStatus(int id, LeaveStatus newStatus)
    {
        await LeaveService.UpdateLeaveStatusAsync(id, newStatus);
        await LoadAsync();
    }

    private async Task ProcessApproval(int id, bool isApproved)
    {
        await LeaveService.ProcessApprovalAsync(id, isApproved, isApproved ? "Onaylandı" : "Reddedildi");

        await LoadAsync();
    }
}