<div class="p-4 mb-2">
    <h4 class="text-white fw-bold mb-0">Hr<span class="text-primary text-opacity-75">Connect</span></h4>
    <small class="text-muted">Management System</small>
</div>

<nav class="flex-column px-2">
    @*HERKESİN GÖREBİLECEĞİ ALAN *@
    <div class="nav-item mb-1">
        <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="" Match="NavLinkMatch.All">
            <i class="bi bi-grid-1x2-fill"></i> <span>Dashboard</span>
        </NavLink>
    </div>

    @*KULLANICININ KENDİ PROFİLİ *@
    <div class="nav-item mb-1">
        <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="profilim">
            <i class="bi bi-person-circle"></i> <span>Profilim</span>
        </NavLink>
    </div>

    @*SADECE ADMIN VE MANAGER GÖREBİLİR *@
    <AuthorizeView Roles="Admin, Manager">
        <Authorized>
            <div class="text-muted small px-3 mt-4 mb-2 text-uppercase fw-bold" style="font-size: 0.7rem;">Organizasyon</div>

            <div class="nav-item mb-1">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="personeller">
                    <i class="bi bi-people-fill"></i> <span>Çalışan Yönetimi</span>
                </NavLink>
            </div>
        </Authorized>
    </AuthorizeView>

    @* SADECE ADMIN GÖREBİLİR *@
    <AuthorizeView Roles="Admin">
        <Authorized>
            <div class="nav-item mb-1">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="departmanlar">
                    <i class="bi bi-diagram-3-fill"></i> <span>Departmanlar</span>
                </NavLink>
            </div>
            <div class="nav-item mb-1">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="pozisyonlar">
                    <i class="bi bi-briefcase-fill"></i> <span>Pozisyonlar</span>
                </NavLink>
            </div>
            <div class="nav-item mb-1">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="raporlar">
                    <i class="bi bi-pie-chart-fill"></i> <span>Analitik Raporlar</span>
                </NavLink>
            </div>
            <div class="nav-item mb-1">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="duyurular">
                    <i class="bi bi-megaphone-fill"></i> <span>Duyuru Yönetimi</span>
                </NavLink>
            </div>
        </Authorized>
    </AuthorizeView>

    <div class="text-muted small px-3 mt-4 mb-2 text-uppercase fw-bold" style="font-size: 0.7rem;">Süreçler</div>

    @*ONAY BEKLEYENLER *@
    <AuthorizeView Roles="Admin, Manager">
        <Authorized>
            <div class="nav-item mb-1">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="onay-bekleyenler">
                    <i class="bi bi-check-circle-fill"></i> <span>Onay Bekleyenler</span>
                </NavLink>
            </div>
        </Authorized>
    </AuthorizeView>

    @*AÇILIR TALEP MENÜSÜ *@
    <div class="nav-item mb-1">
        <div class="nav-link custom-nav-link d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="ToggleTalepler">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-plus-circle-fill"></i> <span>Talep</span>
            </div>
            <i class="bi @(isTaleplerOpen ? "bi-chevron-up" : "bi-chevron-down")" style="font-size: 0.8rem;"></i>
        </div>
        
        @if (isTaleplerOpen)
        {
            <div class="ps-4 mt-1" style="animation: fadeIn 0.3s ease-in-out;">
                <div class="nav-item mb-1">
                    <NavLink class="nav-link custom-nav-link py-2 d-flex align-items-center gap-2" href="izinler" style="font-size: 0.9rem;">
                        <i class="bi bi-calendar-check"></i> <span>İzin</span>
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link custom-nav-link py-2 d-flex align-items-center gap-2" href="avans" style="font-size: 0.9rem;">
                        <i class="bi bi-wallet2"></i> <span>Avans</span>
                    </NavLink>
                </div>
            </div>
        }
    </div>

    <div class="nav-item mb-1">
        <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="kanban">
            <i class="bi bi-kanban-fill"></i> <span>İş Planı (Kanban)</span>
        </NavLink>
    </div>

    @* DESTEK TALEPLERİ *@
    <div class="nav-item mb-1">
        <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="destek">
            <i class="bi bi-headset"></i> <span>Destek</span>
        </NavLink>
    </div>

    @*TAKVİM*@
    <div class="nav-item mb-1">
        <NavLink class="nav-link custom-nav-link d-flex align-items-center gap-2" href="takvim">
            <i class="bi bi-calendar3"></i> <span>Takvim</span>
        </NavLink>
    </div>
</nav>

@code {
    // Açılır kapanır menüyü kontrol eden C# değişkeni
    private bool isTaleplerOpen = false;

    private void ToggleTalepler()
    {
        isTaleplerOpen = !isTaleplerOpen;
    }
}